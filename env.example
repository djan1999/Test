# ── Supabase (required) ──────────────────────────────────────
# Your Supabase project URL (Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — used by the frontend (safe to expose)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — used ONLY by server-side API functions (keep secret!)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Cron / sync auth (required) ─────────────────────────────
# Vercel injects this as Authorization: Bearer <CRON_SECRET> for cron jobs.
# Also used for manual triggers: GET /api/sync-wines?secret=<CRON_SECRET>
CRON_SECRET=your_cron_secret

# Optional separate secret for wine sync triggers
# Defaults to CRON_SECRET if not set
SYNC_SECRET=your_sync_secret

# ── Misc (optional) ──────────────────────────────────────────
VITE_SUPABASE_SERVICE_TABLES=service_tables

# Frontend-accessible sync secret — used by the wine sync admin button.
VITE_SYNC_SECRET=your_sync_secret

# Frontend access gates (optional)
# Leave empty to disable app-wide password and mode-specific PINs.
VITE_ACCESS_PASSWORD=
VITE_PIN_ADMIN=
VITE_PIN_MENU=

# Customizable UI defaults (optional)
VITE_DEFAULT_MENU_TITLE_EN=MENU
VITE_DEFAULT_MENU_TITLE_SI=MENI
VITE_DEFAULT_THANK_YOU_EN=Thank you for your visit.
VITE_DEFAULT_THANK_YOU_SI=Hvala za vaš obisk.
VITE_DEFAULT_TEAM_NAMES=

# Optional quick access defaults (JSON array string)
# Example:
# VITE_DEFAULT_QUICK_ACCESS=[{"label":"House Spritz","searchKey":"spritz","type":"cocktail","enabled":true}]
VITE_DEFAULT_QUICK_ACCESS=

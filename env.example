# ── PowerSync (required for instant/offline service updates) ─
# Public instance URL only; access is authorized with the signed-in user's JWT.
VITE_POWERSYNC_URL=

# ── Supabase (required) ──────────────────────────────────────
# Your Supabase project URL (Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — used by the frontend (safe to expose)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — used ONLY by server-side API functions (keep secret!)
# Must belong to the SAME project as SUPABASE_URL above, or Supabase returns
# "Invalid API key". The newer sb_secret_... keys work too. Accepted aliases:
# SUPABASE_SERVICE_ROLE_KEY, SUPABASE_SECRET_KEY.
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Cron / sync auth (required) ─────────────────────────────
# Vercel injects this as Authorization: Bearer <CRON_SECRET> for cron jobs.
# Used only by Vercel's scheduled GET. Manual admin sync uses the signed-in
# owner's Supabase access token and does not expose this secret to the browser.
CRON_SECRET=your_cron_secret

# Optional second SERVER-ONLY secret for an external automation. Never prefix
# this with VITE_ and never put it in browser code.
SYNC_SECRET=your_sync_secret

# ── Misc (optional) ──────────────────────────────────────────
# Frontend access gates (optional)
# NOTE: When Supabase is configured the app uses real email+password login and
# per-restaurant workspaces, so VITE_ACCESS_PASSWORD is ignored (it only applies
# in local-only mode with no Supabase). The mode PINs still apply.
VITE_ACCESS_PASSWORD=
VITE_PIN_ADMIN=
VITE_PIN_MENU=

# Customizable UI defaults (optional)
VITE_DEFAULT_MENU_TITLE_EN=MENU
VITE_DEFAULT_MENU_TITLE_SI=MENI
VITE_DEFAULT_THANK_YOU_EN=Thank you for your visit.
VITE_DEFAULT_THANK_YOU_SI=Hvala za vaš obisk.
VITE_DEFAULT_TEAM_NAMES=
VITE_APP_NAME=MILKA
VITE_APP_SUBTITLE=SERVICE BOARD
VITE_DEFAULT_SITTING_TIMES=18:00,18:30,19:00,19:15
VITE_DEFAULT_ROOM_OPTIONS=01,11,12,21,22,23

# Hour (0–23, local time) at which the service "day" rolls over. A dinner
# service runs past midnight, so the active service date is NOT considered stale
# until this hour the next morning — protecting the night's drinks/seat input
# from being wiped. Default 6 (06:00). Set to 0 to roll over exactly at midnight.
VITE_SERVICE_DAY_ROLLOVER_HOUR=6

# Optional reservation templates (JSON array string)
# Example:
# VITE_DEFAULT_RESERVATION_TEMPLATES=[{"id":"hotel2","label":"Hotel 2p","data":{"guests":2,"menuType":"long","lang":"en","guestType":"hotel"}}]
VITE_DEFAULT_RESERVATION_TEMPLATES=

# Optional quick access defaults (JSON array string)
# Example:
# VITE_DEFAULT_QUICK_ACCESS=[{"label":"House Spritz","searchKey":"spritz","type":"cocktail","enabled":true}]
VITE_DEFAULT_QUICK_ACCESS=

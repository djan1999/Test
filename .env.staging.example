# Public browser configuration for the isolated reservation lab.
VITE_DEPLOYMENT_ENV=staging
VITE_STAGING_ISOLATION_ACK=MILKA_STAGING_ONLY
VITE_RESERVATIONS_V2_ENABLED=true
VITE_APP_NAME=MILKA RESERVATIONS LAB

# Must be a Supabase branch/project that is NOT production.
VITE_SUPABASE_URL=https://your-staging-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-staging-publishable-or-anon-key

# Keep disabled until a staging-only PowerSync instance is provisioned.
VITE_DISABLE_POWERSYNC=true
VITE_POWERSYNC_URL=

# Server-only Vercel variables. Never prefix secrets with VITE_.
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_SERVICE_KEY=your-staging-secret-key
CRON_SECRET=use-a-different-staging-secret


.red{color:#c04040;}
.center{text-align:center;}
.highlight{background:#edf7ef;}
.course-name{text-transform:uppercase;font-size:8pt;}
.course-sub{font-size:6.5pt;color:#555;font-weight:400;}
.resv-cell{font-size:8pt;line-height:1.15;}
</style></head><body><table><tr class="green-header"><th style="min-width:110pt;text-align:left;padding-left:6pt;">1.06.-7.06.</th><th style="min-width:90pt;text-align:center;">Kovač</th></tr><tr><td style="padding-left:6pt;">Date</td><td class="center">6.06.</td></tr><tr><td style="padding-left:6pt;font-weight:700;">Allergies/Restrictions</td><td class="center" style="line-height:1.3;">LONG MENU<br>1x gluten free, 1x custom_allergy (no coriander)</td></tr><tr><td style="padding-left:6pt;"><span class="course-name">Trout</span><br><span class="course-sub">brook trout, fennel, elderflower</span></td><td class="resv-cell"></td></tr><tr><td style="padding-left:6pt;"><span class="course-name">Venison</span><br><span class="course-sub">loin, blackberry, celeriac</span></td><td class="resv-cell"></td></tr><tr><td style="padding-left:6pt;"><span class="course-name">Walnut Cake</span><br><span class="course-sub">walnut, plum, sour cream</span></td><td class="resv-cell"></td></tr></table></body></html>"
`;


table{border-collapse:collapse;width:auto;table-layout:auto;}
th,td{border:1px solid #aaa;padding:2pt 4pt;vertical-align:top;text-align:left;font-size:8pt;color:#000;font-weight:700;overflow:hidden;word-wrap:break-word;line-height:1.15;}
